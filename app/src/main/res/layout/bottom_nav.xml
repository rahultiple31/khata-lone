<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bottom_nav_background"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <Button
        android:id="@+id/navHomeButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:text="⌂\nHome"
        android:textColor="@color/secondary_text"
        android:textSize="11sp" />

    <Button
        android:id="@+id/navCustomersButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:text="♧\nCustomers"
        android:textColor="@color/secondary_text"
        android:textSize="11sp" />

    <Button
        android:id="@+id/navEntryButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/primary_button_background"
        android:text="+\nEntry"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/navReportsButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:text="▥\nReports"
        android:textColor="@color/secondary_text"
        android:textSize="11sp" />

    <Button
        android:id="@+id/navSettingsButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:text="⚙\nSettings"
        android:textColor="@color/secondary_text"
        android:textSize="11sp" />
</LinearLayout>
