<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_transaction"
            android:textColor="@color/primary_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <Spinner
                android:id="@+id/transactionCustomerSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_background" />

            <RadioGroup
                android:id="@+id/transactionTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/creditRadio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/credit"
                    android:textColor="@color/success"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/debitRadio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/debit"
                    android:textColor="@color/danger"
                    android:textStyle="bold" />
            </RadioGroup>

            <EditText
                android:id="@+id/transactionAmountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_background"
                android:hint="@string/amount"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/transactionNoteInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_background"
                android:hint="@string/note"
                android:inputType="textCapSentences"
                android:maxLines="2"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/saveTransactionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/primary_button_background"
            android:text="@string/save_transaction"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cancelTransactionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/secondary_button_background"
            android:text="@string/back"
            android:textColor="@color/primary"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
